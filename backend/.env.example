# Copy to .env and fill in (do not commit .env)

MONGODB_URL=
DATABASE_NAME=

# Expression AI
GEMINI_API_KEY=

# Azure Blob (session audio)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
